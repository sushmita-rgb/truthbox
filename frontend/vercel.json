{
  "rewrites": [
    {
      "source": "/api/:path*",
      "destination": "https://truthbox-production.up.railway.app/api/:path*"
    },
    {
      "source": "/files/:path*",
      "destination": "https://res.cloudinary.com/:path*"
    },
    {
      "source": "/((?!api/|files/).*)",
      "destination": "/index.html"
    }
  ]
}
